{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "CapyLang",
	"patterns": [
		{
			"include": "#comments"
		},
		{
			"include": "#constants"
		},
		{
			"include": "#types"
		},
		{
			"include": "#keywords"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#variables"
		}
	],
	"repository": {
		"comments": {
			"patterns": [
				{
          			"captures": {
            			"1": {
              				"name": "punctuation.definition.comment.capy"
            			}
          			},
          			"match": "(//).*$",
          			"name": "comment.line.double-slash.capy"
        		}
			]
		},
		"constants": {
			"patterns": [
				{
					"captures": {
						"1": {
							"name": "punctuation.separator.dot.decimal.capy"
						},
						"2": {
							"name": "keyword.operator.exponent.capy"
						},
						"3": {
							"name": "keyword.operator.exponent.sign.capy"
						},
						"4": {
							"name": "constant.numeric.decimal.exponent.mantissa.capy"
						},
						"5": {
							"name": "entity.name.type.numeric.capy"
						}
					},
					"match": "\\b\\d[_\\d]*(\\.?)[_\\d]*(?:([Ee])([-+]?)([_\\d]+))?(f32|f64|i128|i16|i32|i64|i8|u128|u16|u32|u64|u8)?\\b",
					"name": "constant.numeric.decimal.capy"
				}
			]
		},
		"keywords": {
			"patterns": [
				{
					"name": "keyword.control.capy",
					"match": "\\b(if|while|for|return)\\b"
				},
				{
					"match": "\\b(let)\\b",
					"name": "keyword.other.capy storage.type.capy"
				},
				{
          			"match": "\\b(record)\\b",
          			"name": "keyword.declaration.struct.capy storage.type.capy"
        		},
				{
					"name": "keyword.other.capy",
					"match": "\\b(import|as)\\b"
				},
        		{
          			"match": "\\bfn\\b",
          			"name": "keyword.other.fn.capy"
        		}			
			]
		},
		"types": {
			"patterns": [
				{
					"captures": {
						"1": {
							"name": "keyword.declaration.struct.capy storage.type.capy"
						},
						"2": {
							"name": "entity.name.type.struct.capy"
						}
					},
					"match": "\\b(record)\\s+([a-zA-Z0-9_]+)\\b"
				}
			]
		},
		"variables": {
			"patterns": [
				{
					"match": "\\b([_$a-zA-Z][_$a-zA-Z0-9]*)\\b",
					"name": "variable.other.capy"
				}
			]
		},
		"strings": {
			"name": "string.quoted.double.capy",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape.capy",
					"match": "\\\\."
				}
			]
		}
	},
	"scopeName": "source.capy"
}